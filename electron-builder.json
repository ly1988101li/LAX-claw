{
  "appId": "com.lobsterai.app",
  "productName": "LobsterAI",
  "executableName": "LobsterAI",
  "directories": {
    "output": "release"
  },
  "beforePack": "./scripts/electron-builder-hooks.cjs",
  "afterPack": "./scripts/electron-builder-hooks.cjs",
  "files": [
    "package.json",
    "resources/SYSTEM_PROMPT.md",
    {
      "from": "dist",
      "to": "dist",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "dist-electron",
      "to": "dist-electron",
      "filter": [
        "**/*"
      ]
    },
    "!**/*.map",
    "!**/*.d.ts",
    "!**/*.d.cts",
    "!**/*.d.mts",
    "!**/README.md",
    "!**/README",
    "!**/readme.md",
    "!**/CHANGELOG.md",
    "!**/CHANGELOG",
    "!**/HISTORY.md",
    "!**/LICENSE",
    "!**/LICENSE.md",
    "!**/LICENSE.txt",
    "!**/.eslintrc*",
    "!**/.prettierrc*",
    "!**/tsconfig.json",
    "!**/tsconfig.*.json",
    "!**/*.test.*",
    "!**/*.spec.*",
    "!**/tests/**",
    "!**/test/**",
    "!**/__tests__/**"
  ],
  "extraResources": [
    {
      "from": "resources/tray",
      "to": "tray",
      "filter": [
        "**/*"
      ]
    }
  ],
  "protocols": [
    {
      "name": "LobsterAI",
      "schemes": [
        "lobsterai"
      ]
    }
  ],
  "mac": {
    "target": [
      "dmg"
    ],
    "icon": "build/icons/mac/icon.icns",
    "category": "public.app-category.productivity",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "CFBundleIconName": "icon",
      "NSCalendarsUsageDescription": "LobsterAI \u9700\u8981\u8bbf\u95ee\u60a8\u7684\u65e5\u5386\u6765\u5e2e\u52a9\u60a8\u67e5\u770b\u548c\u7ba1\u7406\u65e5\u7a0b\u5b89\u6392\uff0c\u4f8b\u5982\u67e5\u627e\u4e8b\u4ef6\u3001\u521b\u5efa\u4f1a\u8bae\u7b49\u3002",
      "NSRemindersUsageDescription": "LobsterAI \u9700\u8981\u8bbf\u95ee\u60a8\u7684\u63d0\u9192\u4e8b\u9879\u6765\u5e2e\u52a9\u60a8\u7ba1\u7406\u5f85\u529e\u4e8b\u9879\u3002",
      "NSAppleEventsUsageDescription": "LobsterAI \u9700\u8981\u4f7f\u7528 Apple Events \u6765\u63a7\u5236 Calendar \u5e94\u7528\u6267\u884c\u81ea\u52a8\u5316\u64cd\u4f5c\u3002"
    },
    "extraResources": [
      {
        "from": "SKILLs",
        "to": "SKILLs",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.env.*",
          "!**/.venv",
          "!**/.venv/**",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/tsconfig.json",
          "!**/tsconfig.*.json",
          "!**/*.test.*",
          "!**/*.spec.*",
          "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      },
      {
        "from": "vendor/openclaw-runtime/current",
        "to": "cfmind",
        "filter": [
          "**/*",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/tsconfig.json",
          "!**/tsconfig.*.json",
          "!**/*.test.*",
          "!**/*.spec.*",
          "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      }
    ],
    "sign": false
  },
  "dmg": {
    "sign": false
  },
  "afterSign": "scripts/notarize.js",
  "win": {
    "target": [
      "nsis"
    ],
    "icon": "build/icons/win/icon.ico",
    "requestedExecutionLevel": "asInvoker",
    "extraResources": [
      {
        "from": "build-tar/win-resources.tar",
        "to": "win-resources.tar"
      },
      {
        "from": "scripts/unpack-cfmind.cjs",
        "to": "unpack-cfmind.cjs"
      }
    ],
    "sign": false
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "build/icons/png",
    "category": "Utility",
    "extraResources": [
      {
        "from": "SKILLs",
        "to": "SKILLs",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.env.*",
          "!**/.venv",
          "!**/.venv/**",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/tsconfig.json",
          "!**/tsconfig.*.json",
          "!**/*.test.*",
          "!**/*.spec.*",
          "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      },
      {
        "from": "vendor/openclaw-runtime/current",
        "to": "cfmind",
        "filter": [
          "**/*",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/tsconfig.json",
          "!**/tsconfig.*.json",
          "!**/*.test.*",
          "!**/*.spec.*",
          "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      }
    ],
    "desktop": {
      "Name": "LobsterAI",
      "Comment": "AI-assisted coding and productivity tool",
      "Terminal": "false"
    }
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "runAfterFinish": true,
    "deleteAppDataOnUninstall": true,
    "include": "scripts/nsis-installer.nsh"
  },
  "electronVersion": "40.2.1",
  "asarUnpack": [
    "node_modules/@img/**",
    "node_modules/better-sqlite3/**",
    "node_modules/node-nim/**",
    "node_modules/npm/**"
  ],
  "asar": true,
  "publish": false
}